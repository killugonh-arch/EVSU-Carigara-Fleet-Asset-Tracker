          "name": "Delete Asset (Manager)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/assets/1/", "host": ["{{base_url}}"], "path": ["api","assets","1",""] }
          },
          "response": []
