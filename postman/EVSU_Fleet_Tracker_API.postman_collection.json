        {
          "name": "List Assets — Unauthenticated",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/assets/", "host": ["{{base_url}}"], "path": ["api","assets",""] },
            "description": "Expected: 401 Unauthorized — no token provided."
          },
          "response": []
        },
        {
          "name": "Create Asset — Unauthenticated (no token)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"asset_type\": \"vehicle\",\n  \"name\": \"Test Van\",\n  \"asset_tag\": \"VH-9999\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/assets/", "host": ["{{base_url}}"], "path": ["api","assets",""] },
            "description": "Expected: 401 Unauthorized."
          },
          "response": []
