              "raw": "{{base_url}}/api/maintenance/",
              "host": ["{{base_url}}"], "path": ["api","maintenance",""],
              "query": [
                { "key": "status", "value": "pending", "disabled": true },
                { "key": "priority", "value": "high", "disabled": true },
                { "key": "asset", "value": "1", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
