              "raw": "{\n  \"asset_type\": \"vehicle\",\n  \"name\": \"Toyota Hiace Van\",\n  \"asset_tag\": \"VH-2024-001\",\n  \"make\": \"Toyota\",\n  \"model_name\": \"Hiace\",\n  \"year\": 2024,\n  \"serial_number\": \"SN-TH-001\",\n  \"status\": \"available\",\n  \"department\": \"IT\",\n  \"location\": \"EVSU Campus Garage\",\n  \"mileage\": 0,\n  \"fuel_type\": \"diesel\",\n  \"license_plate\": \"ABC 123\",\n  \"next_service_km\": 5000,\n  \"next_maintenance_date\": \"2025-01-01\",\n  \"procurement_cost\": \"1500000.00\",\n  \"current_value\": \"1200000.00\",\n  \"procurement_date\": \"2024-01-15\",\n  \"notes\": \"New acquisition\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/assets/", "host": ["{{base_url}}"], "path": ["api","assets",""] }
