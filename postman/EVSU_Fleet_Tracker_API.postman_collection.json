        {
          "name": "Create Asset — Forbidden (Staff role)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"asset_type\": \"vehicle\",\n  \"name\": \"Unauthorized Van\",\n  \"asset_tag\": \"VH-9999\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/assets/", "host": ["{{base_url}}"], "path": ["api","assets",""] },
            "description": "Login as a Staff/Auditor/Maintenance user first. Expected: 403 Forbidden — only Managers may create assets."
          },
          "response": []
        }
      ]
    },

    {
      "name": "Maintenance Requests",
      "description": "Create and manage maintenance requests. Staff can create & read their own. Manager can approve/reject/complete and read all.",
