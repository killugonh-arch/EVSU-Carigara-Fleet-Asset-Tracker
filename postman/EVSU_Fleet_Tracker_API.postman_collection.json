          "name": "List Assets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/assets/",
              "host": ["{{base_url}}"], "path": ["api","assets",""],
              "query": [
                { "key": "asset_type", "value": "vehicle", "disabled": true },
                { "key": "status", "value": "available", "disabled": true },
                { "key": "department", "value": "IT", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
                { "key": "ordering", "value": "name", "disabled": true }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Retrieve Asset",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/assets/1/", "host": ["{{base_url}}"], "path": ["api","assets","1",""] }
